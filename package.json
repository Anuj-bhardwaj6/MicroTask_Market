{
  "name": "microtask-marketplace-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm run dev:client\" \"npm run server\"",
    "dev:client": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "server": "npm run dev --prefix server",
    "server:install": "npm install --prefix server",
    "server:seed": "npm run seed --prefix server",
    "dev:all": "npm run dev"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "@tanstack/react-query": "^5.101.2",
    "@vitejs/plugin-react": "^4.3.4",
    "axios": "^1.18.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^11.15.0",
    "mongoose": "^9.7.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.4.0",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.1.1",
    "socket.io-client": "^4.7.5",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}

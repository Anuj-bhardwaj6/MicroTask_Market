# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/microtask_marketplace

# Auth - access token (short-lived) + refresh token (long-lived, persistent login)
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d
COOKIE_SECRET=replace_with_a_long_random_secret

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Email (SMTP) - leave blank in development to log OTP/reset emails to the
# console instead of sending them. Fill in to deliver real emails, e.g. with
# Gmail App Passwords, SendGrid, Mailgun, or Resend's SMTP relay.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MicroTask Market <no-reply@microtask.local>

# Cloudinary (task attachment uploads via Multer + Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe (escrow payments). Leave blank in development to use the
# dev-simulated payment path (escrow is marked "held" instantly instead of
# going through a real Stripe Checkout session) - handy for testing the
# full payment flow without live keys. Fill in real test keys from
# https://dashboard.stripe.com/test/apikeys to exercise the real flow.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# From `stripe listen --forward-to localhost:5000/api/wallet/webhook` in dev,
# or the signing secret of the webhook endpoint you configure in Stripe.
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd

# Base URL for the backend API. Left as /api so the Vite dev proxy
# (see vite.config.js) forwards requests to the Express server, and so the
# same build works behind a reverse proxy in production.
VITE_API_URL=/api

# Base URL for the Socket.io connection (chat, live notifications, presence).
# Left blank so the client connects to the same origin serving the page,
# which the Vite dev proxy (see vite.config.js) forwards to the API server
# for local development. Set this explicitly if the frontend and backend are
# deployed on different origins in production.
VITE_SOCKET_URL=
